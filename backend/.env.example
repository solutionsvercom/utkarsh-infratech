# Server
PORT=5001

# Where enquiry emails are delivered (your business inbox)
COMPANY_EMAIL=info@utkarshinfratech.com

# Optional: "From" address (defaults to EMAIL_USER). Some providers require a verified sender.
# EMAIL_FROM=noreply@yourdomain.com

# --- Free / low-cost SMTP (pick one provider and fill the block) ---

# Gmail: use an App Password (Google Account → Security → 2-Step Verification → App passwords)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=youraccount@gmail.com
# EMAIL_PASS=xxxx xxxx xxxx xxxx

# Brevo (formerly Sendinblue) — free tier includes SMTP: create SMTP key in Brevo dashboard
# EMAIL_HOST=smtp-relay.brevo.com
# EMAIL_PORT=587
# EMAIL_USER=your-login@example.com
# EMAIL_PASS=your-smtp-key

# Resend, Mailgun, ZeptoMail, etc. also provide SMTP credentials — use their host/port and API key as EMAIL_PASS where applicable.
